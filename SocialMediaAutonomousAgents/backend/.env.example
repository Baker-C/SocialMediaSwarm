# Copy to .env — never commit .env
RAVENDB_URL=https://localhost
RAVENDB_DB=SocialMediaSwarm
RAVENDB_VERIFY_SSL=false

# If RavenDB returns 403 InvalidAuth ("requires client certificate"), set PEM paths
# or place files under your home directory: ravendb/certs/ (see below).
# RAVENDB_CLIENT_CERT=C:\path\to\client-cert.pem
# RAVENDB_CLIENT_KEY=C:\path\to\private-key.pem
# Or a single PEM that contains both cert and key — set only RAVENDB_CLIENT_CERT.
#
# Auto-discovery (when both vars are empty): ~/ravendb/certs/client.pem [+ client.key],
# client.crt + client.key, or any *.crt with a matching *.key (e.g. ravendb-*.instance.crt).

# Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

SCHEDULER_TIMEZONE=UTC
SCHEDULER_MISFIRE_GRACE_SECONDS=300
# Set false on secondary uvicorn workers so only one process runs :00/:05/:10 jobs
# RUN_SCHEDULER=true
# Set false to pause automatic scheduled posts (forced posts via scripts still work)
# HOURLY_POSTING_ENABLED=false
# Scheduled posting interval (APScheduler IntervalTrigger)
# POST_INTERVAL_MINUTES=20
# Min minutes between posts per account; keep below POST_INTERVAL_MINUTES
# POST_COOLDOWN_MINUTES=18
# POST_LOCK_TTL_SECONDS=600
# Docker: point at host RavenDB (set in docker-compose.yml, not usually in .env)
# RAVENDB_URL=https://host.docker.internal

# Optional: Anthropic Claude for candidate generation + ranking (Messages API)
# ANTHROPIC_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: live RavenDB + X API health (get_me when OAuth1 or OAuth2 user credentials exist on accounts).
# API_HEALTH_CHECK=1
# Legacy alias: TWITTER_API_HEALTH_CHECK=1 (same behavior)

# X / Twitter OAuth 2.0 app (one pair for the backend; used for token refresh flows — do not commit)
# TWITTER_OAUTH2_CLIENT_ID=
# TWITTER_OAUTH2_CLIENT_SECRET=
#
# Per-account X auth is stored encrypted in RavenDB (OAuth 1.0a four fields, or OAuth2 user access
# + optional refresh). Use: python scripts/add_account.py --help
#
# Trends in hourly tick: personalized for the authenticated user first, then WOEID fallback
# TRENDS_PREFER_PERSONALIZED=true
# TRENDS_FALLBACK_WOEID=1

# Print JSON handoffs between hourly pipeline steps (console + log)
# TICK_PIPELINE_TRACE=true

# External reference tweets: recent search by trend (A) + following timeline (B)
# TREND_TWEET_SEARCH_ENABLED=true
# FOLLOWING_FEED_ENABLED=true
# TREND_SEARCH_MAX_RESULTS=100
# FOLLOWING_TIMELINE_MAX_RESULTS=100
# REFERENCE_TWEET_CACHE_MINUTES=45
# FOLLOWING_FEED_FILTER_BY_TREND=true

# Legacy Buffer (optional manual scripts only; core app posts via X/Tweepy)
# BUFFER_API_KEY=
# BUFFER_ORGANIZATION_ID=

LOG_LEVEL=INFO
ENVIRONMENT=development
